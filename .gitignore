# Gitignore for CodeAssistant project

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.coverage
htmlcov/

# Virtual environments
Development/
.env
.venv/
venv/

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# CodeAssistant runtime data (generated at runtime, not source code)
.codeassistant/
*.pyc
